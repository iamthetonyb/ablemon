# ATLAS Environment Configuration
# Copy this to .env and fill in your values
# Store secrets in ~/.atlas/.secrets/ for production

# ──────────────────────────────────────────────
# TELEGRAM
# ──────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_bot_token_here
ATLAS_OWNER_TELEGRAM_ID=your_telegram_id_here
ATLAS_OWNER_USERNAME=your_username_here

# ──────────────────────────────────────────────
# AI PROVIDERS (add at least one)
# ──────────────────────────────────────────────

# NVIDIA NIM (if using NIM gateway)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter (recommended — access to many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local inference — free, no key needed)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (GPT-4, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# ──────────────────────────────────────────────
# PLATFORM TOKENS (for tool dispatch)
# ──────────────────────────────────────────────

GITHUB_TOKEN=your_github_token_here
DO_API_TOKEN=your_digitalocean_token_here
VERCEL_TOKEN=your_vercel_token_here

# ──────────────────────────────────────────────
# SYSTEM CONFIGURATION
# ──────────────────────────────────────────────

ATLAS_TIMEZONE=America/Los_Angeles
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
WEBHOOK_PORT=8080

# ──────────────────────────────────────────────
# WEB SEARCH PROVIDERS (priority: Brave → Perplexity → Gemini → Google → DDG)
# ──────────────────────────────────────────────

# Brave Search API (free tier: 2,000 queries/month)
# Get key: https://api.search.brave.com/register
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Perplexity Sonar (deep research with cited sources — $1/M tokens)
# Get key: https://docs.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini Grounding (free tier: 5,000 grounded prompts/month)
# Get key: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# INTEGRATIONS
# ──────────────────────────────────────────────

NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id
