# ATLAS v2 Environment Configuration
# Copy this to .env and fill in your values

# Telegram Bot (Required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Ollama (For local/hosted LLM)
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM (Free tier)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter (Fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (Premium, for complex reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (For embeddings, optional)
OPENAI_API_KEY=your_openai_api_key_here

# Owner Configuration
ATLAS_OWNER_TELEGRAM_ID=your_telegram_user_id
ATLAS_OWNER_USERNAME=your_telegram_username
ATLAS_TIMEZONE=America/Los_Angeles
