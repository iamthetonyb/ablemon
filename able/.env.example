# ABLE Environment Configuration
# Copy this to .env and fill in your values
# Store secrets in ~/.able/.secrets/ for production

# ──────────────────────────────────────────────
# TELEGRAM
# ──────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_bot_token_here
ABLE_OWNER_TELEGRAM_ID=your_telegram_id_here
ABLE_OWNER_USERNAME=your_username_here

# ──────────────────────────────────────────────
# AI PROVIDERS (add at least one)
# ──────────────────────────────────────────────

# NVIDIA NIM (if using NIM gateway)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter (recommended — access to many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local inference — free, no key needed)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (GPT-4, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# ──────────────────────────────────────────────
# PLATFORM TOKENS (for tool dispatch)
# ──────────────────────────────────────────────

GITHUB_TOKEN=your_github_token_here
DO_API_TOKEN=your_digitalocean_token_here
VERCEL_TOKEN=your_vercel_token_here

# ──────────────────────────────────────────────
# SYSTEM CONFIGURATION
# ──────────────────────────────────────────────

ABLE_TIMEZONE=America/Los_Angeles
# Only the production/server leader should run autonomous cron + Telegram reports.
# Keep false for local/dev to avoid duplicate scheduled messages.
ABLE_CRON_ENABLED=false
# Only the production/server leader should poll the Telegram bot token.
# Keep false for local/dev to avoid "terminated by other getUpdates" conflicts.
ABLE_TELEGRAM_ENABLED=false
# Telegram channel mode: off, polling, or webhook. Webhook mode avoids
# getUpdates conflicts, but requires a public HTTPS URL to /webhook/telegram.
ABLE_TELEGRAM_MODE=off
ABLE_TELEGRAM_WEBHOOK_URL=
ABLE_TELEGRAM_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_PORT=8080

# ──────────────────────────────────────────────
# STRIPE (credit card payments)
# ──────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_CREDITS_PER_USD=100
STRIPE_SUCCESS_URL=https://yourdomain.com/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://yourdomain.com/billing/cancel

# ──────────────────────────────────────────────
# x402 (crypto/USDC payments)
# ──────────────────────────────────────────────
X402_ENABLED=false
X402_PAY_TO_ADDRESS=your_base_wallet_address
X402_NETWORK=base

# ──────────────────────────────────────────────
# WEB SEARCH PROVIDERS (priority: Brave → Perplexity → Gemini → Google → DDG)
# ──────────────────────────────────────────────

# Brave Search API (free tier: 2,000 queries/month)
# Get key: https://api.search.brave.com/register
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Perplexity Sonar (deep research with cited sources — $1/M tokens)
# Get key: https://docs.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini Grounding (free tier: 5,000 grounded prompts/month)
# Get key: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# INTEGRATIONS
# ──────────────────────────────────────────────

NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id

# ──────────────────────────────────────────────
# OBSERVABILITY (Phoenix + TriliumNext)
# ──────────────────────────────────────────────

TRILIUM_URL=http://localhost:8081
TRILIUM_ETAPI_TOKEN=your_trilium_etapi_token_here

# ──────────────────────────────────────────────
# ROUTING OVERRIDES
# ──────────────────────────────────────────────

# Effort level override: LOW | MEDIUM | HIGH | MAX
# ABLE_EFFORT_LEVEL=MEDIUM

# Budget cap in USD (0 = unlimited). Auto-downgrade at <20% remaining.
# ABLE_MAX_BUDGET_USD=0
