# Database (Neon Serverless PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Encryption (AES-256-GCM for API key storage)
ENCRYPTION_KEY="generate-64-hex-chars-with-openssl-rand-hex-32"

# ATLAS Gateway (Python backend)
ATLAS_GATEWAY_URL="http://localhost:8080"

# Service token for gateway ↔ dashboard communication
ATLAS_SERVICE_TOKEN="generate-with-openssl-rand-base64-32"
